<header>
    <nav style="display: flex; gap: 20px; padding: 10px; background-color: #f0f0f0;">
        <div>LOGO</div>
        <div>Főoldal</div>
        <div>Szolgáltatások</div>
        <div>Kapcsolat</div>

        <% if(locals.user) { %>
            <div>Profilom</div>
            <form action="/auth/logout" method="POST">
                <button type="submit">Kijelentkezés</button>
            </form>
        <% } else { %>
            <div><a href="/auth/login">Bejelentkezés</a></div>
            <div><a href="/auth/register">Regisztráció</a></div>
        <% } %>
    </nav>
</header>
