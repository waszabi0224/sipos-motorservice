<div class="modal-backdrop" id="serviceModal">
    <div class="modal">
        <form id="serviceForm" method="POST">
            <div>
                <h1 id="modalTitle">Új szolgáltatás</h1>
            </div>

            <div>
                <label for="name">Név:</label>
                <input type="text" id="name" name="name" required>
            </div>

            <div>
                <label for="description">Leírás:</label>
                <input type="text" id="description" name="description" required>
            </div>

            <div>
                <label for="price">Ár:</label>
                <input type="number" id="price" name="price" required>
            </div>

            <div>
                <label for="duration">Időtartam (perc):</label>
                <input type="text" id="duration" name="duration" required>
            </div>

            <div>
                <label for="is_active">Aktív:</label>
                <select id="is_active" name="is_active">
                    <option value="true">Igen</option>
                    <option value="false">Nem</option>
                </select>
            </div>

            <div class="margin-top: 15px;">
                <button type="submit" id="submitBtn">Létrehozás</button>
                <button type="button" id="closeModalBtn">Mégse</button>
            </div>
        </form>
    </div>
</div>
