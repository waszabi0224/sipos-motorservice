<div class="modal-backdrop" id="bikeModal">
    <div class="modal">
        <form id="bikeForm" method="POST">
            <div>
                <h1 id="modalTitle">Új motor</h1>
            </div>

            <input type="hidden" id="catalog_id" name="catalog_id">

            <div>
                <label for="category">Kategória:</label>
                <select id="category" name="category" style="width: 150px;" required>
                    <option value="">Válassz kategóriát</option>
                    <% if (categories && categories.length > 0) { %>
                        <% categories.forEach(item => { %>
                            <option value="<%= item.category %>"><%= item.category %></option>
                        <% }) %>
                    <% } %>
                </select>
            </div>

            <div>
                <label for="brand">Gyártmány:</label>
                <select id="brand" name="brand" style="width: 150px;" required disabled>
                    <option value=""></option>
                </select>
            </div>

            <div>
                <label for="model">Modell:</label>
                <select id="model" name="model" style="width: 150px;" required disabled>
                    <option value=""></option>
                </select>
            </div>

            <div>
                <label for="cylinder">Henger (cc):</label>
                <select id="cylinder" name="cylinder" style="width: 150px;" required disabled>
                    <option value=""></option>
                </select>
            </div>

            <div>
                <label for="stroke">Ütem:</label>
                <select id="stroke" name="stroke" style="width: 150px;" required disabled>
                    <option value=""></option>
                </select>
            </div>

            <div>
                <label for="generation">Évjárat:</label>
                <select id="generation" name="generation" style="width: 150px;" required disabled>
                    <option value=""></option>
                </select>
            </div>

            <div style="margin-top: 15px;">
                <button type="submit" id="submitBtn">Létrehozás</button>
                <button type="button" id="closeModalBtn">Mégse</button>
            </div>
        </form>
    </div>
</div>
