<!DOCTYPE html>
<html lang="hu">
<head>
    <meta charset="UTF-8">
    <title>Adatok</title>
    <link rel="stylesheet" href="/css/header.css">
    <link rel="stylesheet" href="/css/savedOrNotsavedBike.css">
</head>
<body>
    <%- include("partials/header.ejs") %>

    <h1>Adatok</h1>

    <% if (error) { %>
        <p style="color: red;"><%= error %></p>
    <% } %>

    <form action="/auth/appointment/data" method="POST">
        <div class="section-box">
            <h2>Van már motorod? Válassz!</h2>

            <% if (bikes && bikes.length > 0) { %>
                <div class="bike-option">
                    <label>
                        <input type="radio" name="bike_mode" value="saved" id="savedBikeMode" checked>
                        Motor kiválasztása
                    </label>
                </div>

                <div id="savedBikeSection">
                    <label for="bike_id">Mentett motorjaid:</label>
                    <select class="bike-card" id="bike_id" name="bike_id">
                        <option value="">Válassz egy motort</option>
                        <% bikes.forEach(bike => { %>
                            <option value="<%= bike.id %>">
                                <%= bike.brand %> <%= bike.model %> - <%= bike.cylinder %>cc - <%= bike.generation %>
                            </option>
                        <% }) %>
                    </select>
                </div>

                <div class="bike-option" style="margin-top: 16px;">
                    <label>
                        <input type="radio" name="bike_mode" value="manual" id="manualBikeMode">
                        Másik motor megadása
                    </label>
                </div>
            <% } else { %>
                <input type="hidden" name="bike_mode" value="manual">
                Add meg a motorod adatait!
            <% } %>
        </div>

        <div class="section-box <%= bikes && bikes.length > 0 ? 'hidden' : '' %>" id="manualBikeSection">
            <h2>Új motor adatai</h2>

            <input type="hidden" id="catalog_id" name="catalog_id">

            <div class="bike-form-grid">
                <div>
                    <label for="bike_category">Kategória:</label>
                    <select id="bike_category" name="bike_category">
                        <option value="">Válassz kategóriát</option>
                        <% if (categories && categories.length > 0) { %>
                            <% categories.forEach(item => { %>
                                <option value="<%= item.category %>"><%= item.category %></option>
                            <% }) %>
                        <% } %>
                    </select>
                </div>

                <div>
                    <label for="bike_brand">Gyártmány:</label>
                    <select id="bike_brand" name="bike_brand" disabled>
                        <option value="">Először válassz kategóriát</option>
                    </select>
                </div>

                <div>
                    <label for="bike_model">Modell:</label>
                    <select id="bike_model" name="bike_model" disabled>
                        <option value="">Először válassz gyártmányt</option>
                    </select>
                </div>

                <div>
                    <label for="bike_cylinder">Henger (cc):</label>
                    <select id="bike_cylinder" name="bike_cylinder" disabled>
                        <option value="">Először válassz modellt</option>
                    </select>
                </div>

                <div>
                    <label for="bike_stroke">Ütem:</label>
                    <select id="bike_stroke" name="bike_stroke" disabled>
                        <option value="">Először válassz hengert</option>
                    </select>
                </div>

                <div>
                    <label for="bike_generation">Évjárat:</label>
                    <select id="bike_generation" name="bike_generation" disabled>
                        <option value="">Először válassz ütemet</option>
                    </select>
                </div>
            </div>
        </div>

        <div class="section-box">
            <div class="full-width">
                <label for="note">Megjegyzés:</label>
                <textarea id="note" name="note" rows="3"></textarea>
            </div>
        </div>

        <button type="submit">Befejezés</button>
    </form>

    <script src="/js/savedOrNotsavedBike.js"></script>
</body>
</html>
