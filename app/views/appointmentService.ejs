<!DOCTYPE html>
<html lang="hu">
<head>
    <meta charset="UTF-8">
    <title>Szolgáltatások</title>
    <link rel="stylesheet" href="/css/header.css">
</head>
<body>
    <%- include("partials/header.ejs") %>

    <h1>Szolgáltatások</h1>
    <p>Itt láthatod az összes szolgáltatást.</p>
    <% if (!services || services.length === 0) { %>
        <p>Nincsenek szolgáltatások.</p>
    <% } else { %>
        <table border="1" cellpadding="8">
            <thead>
                <tr>
                    <th>Név</th>
                    <th>Leírás</th>
                    <th>Ár</th>
                    <th>Időtartam</th>
                    <th>Aktív-e</th>
                    <th>Létrehozva</th>
                    <th>Frissítve</th>
                </tr>
            </thead>
            <tbody>
                <form action="/auth/appointment/service" method="POST">
                    <% active_services.forEach(active_service => { %>
                        <tr>    
                            <td><%= active_service.name %></td>
                            <td><%= active_service.description %></td>
                            <td><%= active_service.price %></td>
                            <td><%= active_service.duration %></td>
                            <td><%= active_service.is_active %></td>
                            <td><%= new Date(active_service.created_at).toLocaleString() %></td>
                            <td><%= new Date(active_service.updated_at).toLocaleString() %></td>
                            <td>
                                <label>
                                    <input type="checkbox" name="service_ids" value="<%= active_service.id %>">
                                </label>
                            </td>                        
                        </tr>
                    <% }); %>
                    <button type="submit">Tovább</button>
                </form>
            </tbody>
        </table>
    <% } %>
</body>
</html>
