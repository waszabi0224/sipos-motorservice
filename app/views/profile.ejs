<!DOCTYPE html>
<html lang="hu">
<head>
    <meta charset="UTF-8">
    <title>Saját adataim</title>
    <link rel="stylesheet" href="/css/header.css">
    <link rel="stylesheet" href="/css/serviceModal.css">
</head>
<body>
    <%- include("partials/header.ejs") %>
    <%- include("partials/bikeModal.ejs") %>

    <h1>Saját profilom</h1>

    <ul>
        <li><strong>Vezetéknév:</strong> <%= user.last_name %></li>
        <li><strong>Keresztnév:</strong> <%= user.first_name %></li>
        <li><strong>Email:</strong> <%= user.email %></li>
        <li><strong>Szerep:</strong> <%= user.role %></li>
        <li><strong>Telefonszám:</strong> <%= user.phone %></li>
        <li><strong>Létrehozva:</strong> <%= new Date(user.created_at).toLocaleString() %></li>
    </ul>

    <% if(user.role === "customer") { %>
        <p style="font-size: large;">Időpontok</p>

        <% if (!appointments || appointments.length === 0) { %>
            <p>Nincsenek időpontok.</p>
        <% } else { %>
            <table border="1" cellpadding="8">
                <thead>
                    <tr>
                        <th>Dátum</th>
                        <th>Idő</th>
                        <th>Kategória</th>
                        <th>Márka</th>
                        <th>Modell</th>
                        <th>Henger</th>
                        <th>Ütem (cc)</th>
                        <th>Évjárat</th>
                        <th>Létrehozva</th>
                        <th>Megjegyzés</th>
                        <th>Státusz</th>
                        <th>Szolgáltatás</th>
                    </tr>
                </thead>
                <tbody>
                    <% appointments.forEach(appointment => { %>
                        <tr>
                            <td><%= new Date(appointment.appointment_date).toLocaleDateString() %></td>                        
                            <td><%= appointment.appointment_time %></td>
                            <td><%= appointment.category %></td>
                            <td><%= appointment.brand %></td>
                            <td><%= appointment.model %></td>
                            <td><%= appointment.cylinder %></td>
                            <td><%= appointment.stroke %></td>
                            <td><%= appointment.generation %></td>
                            <td><%= new Date(appointment.created_at).toLocaleString() %></td>
                            <td><%= appointment.note %></td>
                            <td><%= appointment.status %></td>
                            <td><%= appointment.services %></td>
                        </tr>
                    <% }); %>
                </tbody>
            </table>
        <% } %>

        <p style="font-size: large;">Motorjaim</p>

        <% if (!bikes || bikes.length === 0) { %>
            <p>Nincsenek motorok.</p>
        <% } else { %>
            <table border="1" cellpadding="8">
                <thead>
                    <tr>
                        <th>Gyártmány</th>
                        <th>Modell</th>
                        <th>Henger (cc)</th>
                        <th>Kategória</th>
                        <th>Ütem</th>
                        <th>Évjárat</th>
                        <th>Létrehozva</th>
                    </tr>
                </thead>
                <tbody>
                    <% bikes.forEach(bike => { %>
                        <tr class="bike-row">
                            <td>
                                <button type="button" class="bike-toggle-details" data-bike-id="<%= bike.id %>">
                                    <%= bike.brand %>
                                </button>
                            </td>
                            <td><%= bike.model %></td>
                            <td><%= bike.cylinder %></td>
                            <td><%= bike.category %></td>
                            <td><%= bike.stroke %></td>
                            <td><%= bike.generation %></td>
                            <td><%= new Date(bike.created_at).toLocaleString() %></td>
                            <td>
                                <button type="button" class="editBikeBtn" data-id="<%= bike.id %>" data-catalog-id="<%= bike.catalog_id %>" data-category="<%= bike.category %>" data-brand="<%= bike.brand %>" data-model="<%= bike.model %>" data-cylinder="<%= bike.cylinder %>" data-stroke="<%= bike.stroke %>" data-generation="<%= bike.generation %>">Módosítás</button>
                            </td>
                            <td>
                                <form action="/auth/bikes/<%=bike.id%>?_method=DELETE" method="POST">
                                    <button type="submit">Törlés</button>
                                </form>
                            </td>
                        </tr>

                        <tr id="bike-details-<%= bike.id %>" style="display: none;">
                            <td colspan="5">
                                <% if(bike.bike_services && bike.bike_services.length > 0) { %>
                                    <table border="1" cellpadding="8">
                                        <thead>
                                            <tr>
                                                <th>Név</th>
                                                <th>Leírás</th>
                                                <th>Ár</th>
                                                <th>Időtartam</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            <% bike.bike_services.forEach(bike_service => { %>
                                                <tr>
                                                    <td><%= bike_service.name %></td>
                                                    <td><%= bike_service.description %></td>
                                                    <td><%= bike_service.price %></td>
                                                    <td><%= bike_service.duration %></td>
                                                </tr>
                                            <% }) %>
                                        </tbody>
                                    </table>
                                <% } else { %>
                                    <p>Nincs szervíz ehhez a motorhoz.</p>
                                <% } %>
                            </td>
                        </tr>
                    <% }); %>
                </tbody>
            </table>
        <% } %>

        <button type="button" id="openModalBtn">Új motor</button>

        <script src="/js/bikeModal.js"></script>
        <script src="/js/bikeServices.js"></script>

    <% } %>
</body>
</html>
