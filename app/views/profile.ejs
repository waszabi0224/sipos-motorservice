<!DOCTYPE html>
<html lang="hu">
<head>
    <meta charset="UTF-8">
    <title>Saját adataim</title>
    <link rel="stylesheet" href="/css/header.css">
</head>
<body>
    <%- include("partials/header.ejs") %>

    <h1>Saját profilom</h1>

    <ul>
        <li><strong>Vezetéknév:</strong> <%= user.last_name %></li>
        <li><strong>Keresztnév:</strong> <%= user.first_name %></li>
        <li><strong>Email:</strong> <%= user.email %></li>
        <li><strong>Szerep:</strong> <%= user.role %></li>
        <li><strong>Telefonszám:</strong> <%= user.phone %></li>
        <li><strong>Létrehozva:</strong> <%= new Date(user.created_at).toLocaleString() %></li>
    </ul>

    <% if(user.role === "customer") { %>
        <p style="font-size: large;">Időpontok</p>

        <% if (!appointments || appointments.length === 0) { %>
        <p>Nincsenek időpontok.</p>
        <% } else { %>
        <table border="1" cellpadding="8">
            <thead>
                <tr>
                    <th>Dátum</th>
                    <th>Idő</th>
                    <th>Márka</th>
                    <th>Típus</th>
                    <th>Rendszám</th>
                    <th>Megjegyzés</th>
                    <th>Létrehozva</th>
                    <th>Szolgáltatás</th>
                    <th>Státusz</th>
                </tr>
            </thead>
            <tbody>
                <% appointments.forEach(appointment => { %>
                    <tr>
                        <td><%= new Date(appointment.appointment_date).toLocaleDateString() %></td>                        
                        <td><%= appointment.appointment_time %></td>
                        <td><%= appointment.vehicle_brand %></td>
                        <td><%= appointment.vehicle_type %></td>
                        <td><%= appointment.license_plate %></td>
                        <td><%= appointment.note %></td>
                        <td><%= new Date(appointment.created_at).toLocaleString() %></td>
                        <td><%= appointment.services %></td>
                        <td><%= appointment.status %></td>
                    </tr>
                <% }); %>
            </tbody>
        </table>
        <% } %>
    <% } %>

    <p style="font-size: large;">Motorjaim</p>

</body>
</html>
