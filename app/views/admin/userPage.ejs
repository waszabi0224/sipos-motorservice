<!DOCTYPE html>
<html lang="hu">
<head>
    <meta charset="UTF-8">
    <title>Felhasználó</title>
    <link rel="stylesheet" href="/css/header.css">
</head>
<body>
    <%- include("../partials/header.ejs") %>

    <h1>Felhasználó</h1>
    <p>Itt láthatod a felhasználót.</p>
    <ul>
        <li><strong>Vezetéknév:</strong> <%= selectedUser.last_name %></li>
        <li><strong>Keresztnév:</strong> <%= selectedUser.first_name %></li>
        <li><strong>Email:</strong> <%= selectedUser.email %></li>
        <li><strong>Szerep:</strong> <%= selectedUser.role %></li>
        <li><strong>Telefonszám:</strong> <%= selectedUser.phone %></li>
        <li><strong>Létrehozva:</strong> <%= new Date(selectedUser.created_at).toLocaleString() %></li>
    </ul>

    <p style="font-size: large;">Időpontok</p>

    <% if (!appointments || appointments.length === 0) { %>
        <p>Nincsenek időpontok.</p>
    <% } else { %>
        <table border="1" cellpadding="8">
            <thead>
                <tr>
                    <th>Dátum</th>
                    <th>Idő</th>
                    <th>Gyártmány</th>
                    <th>Modell</th>
                    <th>Típus</th>
                    <th>Ütem</th>
                    <th>Henger (cc)</th>
                    <th>Évjárat</th>
                    <th>Megjegyzés</th>
                    <th>Létrehozva</th>
                    <th>Szolgáltatás</th>
                    <th>Státusz</th>
                </tr>
            </thead>
            <tbody>
                <% appointments.forEach(appointment => { %>
                    <tr>
                        <td><%= new Date(appointment.appointment_date).toLocaleDateString() %></td>                        
                        <td><%= appointment.appointment_time %></td>
                        <td><%= appointment.bike_brand %></td>
                        <td><%= appointment.bike_model %></td>
                        <td><%= appointment.bike_type %></td>
                        <td><%= appointment.bike_stroke %></td>
                        <td><%= appointment.bike_cylinder %></td>
                        <td><%= appointment.bike_generation %></td>
                        <td><%= appointment.note %></td>
                        <td><%= new Date(appointment.created_at).toLocaleString() %></td>
                        <td><%= appointment.services %></td>
                        <td>
                            <form action="/admin/appointments/<%= appointment.id %>?_method=PATCH" method="POST" style="display: flex; gap: 8px; align-items: center;">
                                <select name="status">
                                    <option value="Feldolgozás alatt" <%= appointment.status === "Feldolgozás alatt" ? "selected" : "" %>>
                                        Feldolgozás alatt
                                    </option>

                                    <option value="Elfogadva" <%= appointment.status === "Elfogadva" ? "selected" : "" %>>
                                        Elfogadva
                                    </option>

                                    <option value="Folyamatban" <%= appointment.status === "Folyamatban" ? "selected" : "" %>>
                                        Folyamatban
                                    </option>

                                    <option value="Teljesítve" <%= appointment.status === "Teljesítve" ? "selected" : "" %>>
                                        Teljesítve
                                    </option>
                                </select>

                                <input type="hidden" name="redirectTo" value="/admin/users/<%= selectedUser.id %>">
                                <button type="submit">Mentés</button>
                            </form>
                        </td>
                    </tr>
                <% }); %>
            </tbody>
        </table>
    <% } %>
    
    <p style="font-size: large;">Motorok</p>

    <% if (!bikes || bikes.length === 0) { %>
        <p>Nincsenek motorok.</p>
    <% } else { %>
        <table border="1" cellpadding="8">
            <thead>
                <tr>
                    <th>Gyártmány</th>
                    <th>Modell</th>
                    <th>Típus</th>
                    <th>Kategória</th>
                    <th>Ütem</th>
                    <th>Henger (cc)</th>
                    <th>Évjárat</th>
                    <th>Létrehozva</th>
                </tr>
            </thead>
            <tbody>
                <% bikes.forEach(bike => { %>
                    <tr>
                        <td><%= bike.brand %></td>
                        <td><%= bike.model %></td>
                        <td><%= bike.type %></td>
                        <td><%= bike.category %></td>
                        <td><%= bike.stroke %></td>
                        <td><%= bike.cylinder %></td>
                        <td><%= bike.generation %></td>
                        <td><%= new Date(bike.created_at).toLocaleString() %></td>
                    </tr>
                <% }); %>
            </tbody>
        </table>
    <% } %>
</body>
</html>
