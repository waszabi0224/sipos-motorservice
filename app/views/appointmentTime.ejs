<!DOCTYPE html>
<html lang="hu">
<head>
    <meta charset="UTF-8">
    <title>Időpont választás</title>
    <link rel="stylesheet" href="/css/appointmentTime.css">
    <link rel="stylesheet" href="/css/header.css">
</head>
<body>
    <%- include("partials/header.ejs") %>

    <h1>Válassz napot és időpontot</h1>

    <% if (error) { %>
        <p><%= error %></p>
    <% } %>

    <form action="/auth/appointment/time" method="POST">
        <input type="hidden" id="appointment_date" name="appointment_date" required>

        <div class="calendar-wrapper">
            <div class="calendar-header">
                <button type="button" id="prevMonthBtn">&lt;</button>
                <h2 id="calendarTitle"></h2>
                <button type="button" id="nextMonthBtn">&gt;</button>
            </div>

            <div class="calendar-weekdays">
                <div>Hé</div>
                <div>Ke</div>
                <div>Sze</div>
                <div>Csü</div>
                <div>Pé</div>
                <div>Szo</div>
                <div>Va</div>
            </div>

            <div id="calendarGrid" class="calendar-grid"></div>
        </div>

        <h2>Kiválasztott nap: <span id="selectedDateText">nincs kiválasztva</span></h2>

        <div class="times-wrapper">
            <h3>Szabad időpontok</h3>

            <%
                const timeSlots = ["08:00", "09:00", "10:00", "11:00", "13:00", "14:00", "15:00", "16:00"];
            %>

            <div class="time-slots">
                <% timeSlots.forEach(time => { %>
                    <label class="time-slot">
                        <input type="radio" name="appointment_time" value="<%= time %>" class="timeCheck" required>
                        <span><%= time %></span>
                    </label>
                <% }) %>
            </div>
        </div>

        <div>
            <div class="method-option">
                <label>
                    <input type="radio" name="delivery_method" value="personal" id="personalDelivery" checked>
                        Személyes ügyintézés
                </label>
            </div>

            <div class="method-option">
                <label>
                    <input type="radio" name="delivery_method" value="shipping" id="shippingDelivery" checked>
                        Szállítással
                </label>
            </div>
        </div>

        <div>
            <div class="urgency-option">
                <label>
                    <input type="radio" name="service_urgency" value="urgent" id="urgentService" checked>
                        Sürgős (1-3 nap)
                </label>
            </div>

            <div class="urgency-option">
                <label>
                    <input type="radio" name="service_urgency" value="flexible" id="flexibleService" checked>
                        Ráér (1-3 hét)
                </label>
            </div>
        </div>

        <button type="submit" id="nextBtn" disabled>Tovább</button>
    </form>

    <script src="/js/appointmentCalendar.js"></script>
</body>
</html>